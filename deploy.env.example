# Copy to project root as ".env" (same folder as docker-compose.prod.yml). Do not commit.
# JWT: use long random ASCII in production (>= 32 chars). Below works for first local Docker run.
JWT_ACCESS_SECRET=change-me-access-min-32-chars-docker-local-only!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-docker-local-only!!

# 對外網頁埠（主機上映射）；預設 8080 避免與本機 80 衝突
WEB_PORT=8080

# 前端建置時嵌入（Gemini）；可不填，視功能而定
GEMINI_API_KEY=

# 選填：天氣 API（後端）
WEATHER_API_KEY=
WEATHER_API_HOST=https://devapi.qweather.com

# 選填：Redis 密碼（redis 服務未設密碼時留空）
REDIS_PASSWORD=

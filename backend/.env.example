NODE_ENV=development
PORT=4000

# Redis（必填：全部业务数据持久化在 Redis，不再使用 PostgreSQL）
# 本地开发：npm run start:dev 会通过 redis-memory-server 自动分配端口并覆盖 REDIS_*，无需 Docker。
# 若使用本机或 Docker 里的 Redis：改用 npm run start:dev:live-redis，并填写下列 HOST/PORT。
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-access-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars!!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# 天气：和风天气 QWeather（API KEY 方式）
# 在控制台查看你的独立 API Host（推荐）；不填则使用 devapi.qweather.com
WEATHER_API_HOST=https://devapi.qweather.com
# API KEY 凭据（勿提交到 Git）
WEATHER_API_KEY=
# 凭据 ID（可选，仅作本地备注；JWT 方式才用于 kid）
WEATHER_CREDENTIAL_ID=
# 遗留字段，一般留空
WEATHER_API_URL=

# 音频配置（后端仅存元数据/偏好，不托管流媒体）
AUDIO_DEFAULT_TYPE=ambient

# 软删除物理清理：超过该天数的软删记录将被删除（定时任务每日 3 点）
SOFT_DELETE_RETENTION_DAYS=90
